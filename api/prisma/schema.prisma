generator client {
  provider      = "prisma-client-js"
  // Ship binaries for both glibc (Railway/Nixpacks) and musl (Dockerfile) runtimes
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String   @id @default(uuid())
  name               String
  logoDataUrl        String?
  backgroundColor    String?
  surfaceColor       String?
  cardColor          String?
  foregroundColor    String?
  mutedColor         String?
  accentColor        String?
  accentColor2       String?
  crmMode            String   @default("B2B")
  crmDisplayCurrency String   @default("USD")
  industry           String?
  contractSetup      Json?
  marketingSetup     Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users                     User[]
  clients                   Client[]
  tasks                     Task[]
  invoices                  Invoice[]
  subscriptions             Subscription[]
  pipelines                 Pipeline[]
  stages                    Stage[]
  deals                     Deal[]
  dealStageHistory          DealStageHistory[]
  products                  Product[]
  dealItems                 DealItem[]
  postSalesCases            PostSalesCase[]
  userInvites               UserInvite[]
  legalAcceptances          LegalAcceptance[]
  googleCalendarConnections GoogleCalendarConnection[]
  clientCollaborators       ClientCollaborator[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(MEMBER)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id])
  deals                    Deal[]                    @relation("DealOwner")
  clientsOwned             Client[]                  @relation("ClientOwner")
  postSalesCasesOwned      PostSalesCase[]           @relation("PostSalesCaseOwner")
  legalAcceptances         LegalAcceptance[]
  googleCalendarConnection GoogleCalendarConnection?
}

model LegalAcceptance {
  id              String   @id @default(uuid())
  tenantId        String
  userId          String?
  email           String
  contractVersion String
  country         String?
  acceptedAt      DateTime @default(now())
  ipAddress       String?
  userAgent       String?
  source          String   @default("SIGNUP")
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@index([contractVersion])
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String
  customerTenantId String             @unique
  customerName     String
  customerCountry  String?
  customerAddress  String?
  contactFirstName String?
  contactLastName  String?
  contactEmail     String?
  plan             String             @default("TRIAL")
  seats            Int                @default(1)
  trialEndsAt      DateTime?
  trialAlertSentAt DateTime?
  stripeCustomerId String?
  stripeSubscriptionId String?        @unique
  stripePriceId    String?
  billingEmail     String?
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean           @default(false)
  status           SubscriptionStatus @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model UserInvite {
  id               String       @id @default(uuid())
  tenantId         String
  email            String
  name             String?
  role             UserRole     @default(MEMBER)
  token            String       @unique
  status           InviteStatus @default(PENDING)
  invitedByUserId  String?
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, email])
}

model Client {
  id            String   @id @default(uuid())
  firstName     String?
  name          String
  function      String?
  companySector String?
  clientStatus  String   @default("CLIENT")
  dateOfBirth   String?
  email         String?
  phone         String?
  company       String?
  website       String?
  address       String?
  taxId         String?
  notes         String?
  ownerUserId   String?
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  owner         User?                @relation("ClientOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks         Task[]
  invoices      Invoice[]
  deals         Deal[]
  postSalesCases PostSalesCase[]
  collaborators ClientCollaborator[]

  @@index([ownerUserId])
}

model ClientCollaborator {
  id        String   @id @default(uuid())
  tenantId  String
  clientId  String
  firstName String?
  name      String
  function  String?
  email     String?
  whatsapp  String?
  comments  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, clientId])
}

model Task {
  id             String     @id @default(uuid())
  title          String
  status         TaskStatus @default(PENDING)
  dueDate        DateTime?
  timeSpentHours Decimal?   @db.Decimal(8, 2)
  amount         Decimal?   @db.Decimal(12, 2)
  currency       String     @default("USD")
  tenantId       String
  clientId       String
  postSalesCaseId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  client        Client         @relation(fields: [clientId], references: [id])
  postSalesCase PostSalesCase? @relation(fields: [postSalesCaseId], references: [id], onDelete: SetNull)
}

model GoogleCalendarConnection {
  id                 String    @id @default(uuid())
  tenantId           String
  userId             String    @unique
  googleEmail        String
  refreshTokenCipher String
  calendarId         String    @default("primary")
  calendarSummary    String?
  lastSyncAt         DateTime?
  lastSyncError      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Invoice {
  id           String        @id @default(uuid())
  tenantId     String
  clientId     String?
  amount       Decimal       @db.Decimal(10, 2)
  currency     String        @default("USD")
  status       InvoiceStatus @default(NEW)
  filePath     String
  issuedDate   DateTime?
  dueDate      DateTime?
  extractedRaw Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  stages Stage[]
  deals  Deal[]
}

model Stage {
  id          String      @id @default(uuid())
  name        String
  position    Int
  probability Float       @default(0)
  status      StageStatus @default(OPEN)
  tenantId    String
  pipelineId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  pipeline    Pipeline           @relation(fields: [pipelineId], references: [id])
  deals       Deal[]
  historyFrom DealStageHistory[] @relation("FromStage")
  historyTo   DealStageHistory[] @relation("ToStage")
}

model Deal {
  id                String    @id @default(uuid())
  title             String
  value             Decimal   @db.Decimal(12, 2)
  currency          String    @default("USD")
  probability       Float?
  expectedCloseDate DateTime?
  proposalFilePath  String?
  clientId          String?
  ownerId           String?
  tenantId          String
  pipelineId        String
  stageId           String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id])
  client   Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner    User?              @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipeline Pipeline           @relation(fields: [pipelineId], references: [id])
  stage    Stage              @relation(fields: [stageId], references: [id])
  history  DealStageHistory[]
  items    DealItem[]
  postSalesCase PostSalesCase?

  @@index([ownerId])
}

model PostSalesCase {
  id          String              @id @default(uuid())
  tenantId    String
  clientId    String?
  dealId      String?             @unique
  name        String
  status      PostSalesCaseStatus @default(onboarding)
  priority    PostSalesPriority   @default(medium)
  ownerUserId String?
  dueDate     DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)
  owner User? @relation("PostSalesCaseOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks Task[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([clientId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal? @db.Decimal(12, 2)
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  dealItems DealItem[]

  @@index([tenantId])
}

model DealItem {
  id        String   @id @default(uuid())
  tenantId  String
  dealId    String
  productId String
  quantity  Int      @default(1)
  unitPrice Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([dealId, productId])
  @@index([tenantId])
  @@index([dealId])
  @@index([productId])
}

model DealStageHistory {
  id          String   @id @default(uuid())
  tenantId    String
  dealId      String
  fromStageId String?
  toStageId   String
  movedAt     DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  deal      Deal   @relation(fields: [dealId], references: [id])
  fromStage Stage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   Stage  @relation("ToStage", fields: [toStageId], references: [id])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum InvoiceStatus {
  NEW
  PROCESSING
  READY
}

enum StageStatus {
  OPEN
  WON
  LOST
}

enum PostSalesCaseStatus {
  onboarding
  collecting_info
  in_progress
  waiting_client
  internal_review
  delivery
  support
  done
}

enum PostSalesPriority {
  low
  medium
  high
  urgent
}
